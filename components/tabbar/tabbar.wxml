<!--components/tabbar/tabbar.wxml-->
<view class="custom-tabbar">
  <view 
    class="tab-item {{currentIndex === 0 ? 'active' : ''}}" 
    bindtap="onTabTap" 
    data-index="0"
  >
    <image 
      class="tab-icon" 
      src="{{currentIndex === 0 ? '/images/tabbar-home-active.png' : '/images/tabbar-home.png'}}" 
      mode="aspectFit"
    ></image>
    <view class="tab-text">去水印</view>
  </view>
  
  <view 
    class="tab-item {{currentIndex === 1 ? 'active' : ''}}" 
    bindtap="onTabTap" 
    data-index="1"
  >
    <image 
      class="tab-icon" 
      src="{{currentIndex === 1 ? '/images/tabbar-profile-active.png' : '/images/tabbar-profile.png'}}" 
      mode="aspectFit"
    ></image>
    <view class="tab-text">个人中心</view>
  </view>
</view>