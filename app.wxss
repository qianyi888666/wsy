/* 全局样式 */
page {
  background: linear-gradient(145deg, #1a1d29 0%, #2d3142 40%, #3d4258 70%, #4a5066 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  color: #000000;
  line-height: 1.6;
  height: 100vh;
  overflow-y: auto;
}

.container {
  padding: 20rpx;
}

.card {
  background: linear-gradient(135deg, rgba(45, 49, 66, 0.8) 0%, rgba(255, 255, 255, 0.8) 100%);
  backdrop-filter: blur(20px);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(116, 185, 255, 0.2);
}

.btn-primary {
  background: linear-gradient(135deg, rgba(45, 49, 66, 0.9) 0%, rgba(255, 255, 255, 0.8) 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(116, 185, 255, 0.4);
}

.btn-secondary {
  background: linear-gradient(135deg, rgba(45, 49, 66, 0.8) 0%, rgba(255, 255, 255, 0.8) 100%);
  color: #000000;
  font-weight: 600;
  border: 1rpx solid rgba(116, 185, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  backdrop-filter: blur(5px);
}

.btn-secondary:active {
  transform: translateY(2rpx);
  background: linear-gradient(135deg, rgba(45, 49, 66, 0.9) 0%, rgba(255, 255, 255, 0.9) 100%);
}

.btn-success {
  background: linear-gradient(135deg, rgba(45, 49, 66, 0.9) 0%, rgba(255, 255, 255, 0.8) 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-success::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.btn-success:active::before {
  left: 100%;
}

.btn-success:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(162, 155, 254, 0.3);
}

/* 通用动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}