page {
  --color-primary: #FF6B35;
  --color-primary-light: #FF8C42;
  --color-primary-dark: #E55A2B;
  --color-secondary: #FF6B6B;
  --color-accent: #FFD93D;
  --color-success: #2ECC71;
  --color-error: #E74C3C;
  --color-white: #FFFFFF;
  --color-bg: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 50%, #FFF9E6 100%);
  --color-bg-secondary: linear-gradient(180deg, #FFFFFF 0%, #FFF9E6 100%);
  --color-bg-card: linear-gradient(180deg, #FFFFFF 0%, #FFFBF0 100%);
  --color-text-primary: #2D3436;
  --color-text-secondary: #636E72;
  --color-text-tertiary: #B2BEC3;
  --color-text-placeholder: #DFE6E9;
  --color-border: #FFE4D6;
  --color-border-strong: #FFD4B8;
}

page {
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-xxl: 64rpx;
}

page {
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
}

page {
  --shadow-sm: 0 2px 8px rgba(255, 107, 53, 0.08);
  --shadow-md: 0 4px 16px rgba(255, 107, 53, 0.12);
  --shadow-lg: 0 8px 32px rgba(255, 107, 53, 0.16);
  --shadow-glow: 0 0 20px rgba(255, 107, 53, 0.3);
}

page {
  background: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  color: var(--color-text-secondary);
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
  overflow-y: auto;
}

.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-border);
  margin-bottom: var(--spacing-md);
  overflow: hidden;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: var(--color-white);
  border: none;
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-top: var(--spacing-md);
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.btn-secondary {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF9E6 100%);
  color: var(--color-primary);
  font-weight: 600;
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary:active {
  transform: scale(0.96);
  background: linear-gradient(180deg, #FFF5EB 0%, #FFE8CC 100%);
}

.btn-success {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  color: var(--color-white);
  border: none;
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: var(--spacing-md);
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-success:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.btn-disabled {
  background: linear-gradient(180deg, #F5F5F5 0%, #E8E8E8 100%);
  color: var(--color-text-placeholder);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: var(--spacing-md);
  box-shadow: none;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  padding: var(--spacing-lg);
}

@keyframes fadeIn {
  from { 
    opacity: 0; 
  }
  to { 
    opacity: 1; 
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes announcement-scroll {
  0% {
    transform: translateX(100%);
  }
  100% {
    transform: translateX(-100%);
  }
}
