<view class="page-container">
  <view class="announcement-bar">
    <view class="announcement-wrapper">
      <view class="announcement-content-wrapper">
        <view class="announcement-content">
          <text class="announcement-text">{{announcementContent}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="container" style="--status-bar-height: {{statusBarHeight}}px;">
    <view class="harmonyos-tip" wx:if="{{isHarmonyOS}}">
      <text class="harmonyos-tip-text">您正在使用 HarmonyOS 设备，已为您优化体验</text>
    </view>
  
    <view class="header-section">
      <view class="main-title">去水印小工具</view>
      <view class="sub-title">仅支持个人非商用视频或图集素材去水印</view>
      <view class="notice-compact">
        <view class="notice-label">公告</view>
        <text class="notice-compact-text">{{noticeContent}}</text>
      </view>
    </view>

    <view class="input-section">
      <view class="input-card">
        <view class="input-header">
          <view class="input-title">去水印链接填写</view>
        </view>
        <view class="input-wrapper">
          <textarea 
            class="input-modern" 
            placeholder="请输入视频或图集作品链接" 
            value="{{videoUrl}}"
            bindinput="onUrlInput"
          ></textarea>
        </view>
      </view>
      
      <view class="button-container">
        <button 
          class="btn-modern {{loading || adLoading || !videoUrl ? 'btn-disabled' : ''}} {{videoUrl ? 'btn-ready' : ''}}" 
          bindtap="parseVideo"
          loading="{{loading || adLoading}}"
          disabled="{{loading || adLoading || !videoUrl}}"
        >
          <text class="btn-text">
            {{loading ? '去水印中，请稍后...' : (adLoading ? '广告加载中...' : '一键去水印')}}
          </text>
        </button>
      </view>
    </view>
    
    <view class="customer-service-wrapper">
      <view class="customer-service-ripple"></view>
      <button class="customer-service-float" bindtap="showCustomerServiceTip" open-type="contact">
        <image class="service-icon" src="/images/kf.png" mode="aspectFit"></image>
      </button>
    </view>

    <view class="ad-loading-section" wx:if="{{adLoading && !loading}}">
      <view class="ad-loading-animation">
        <view class="ad-loading-icon">📺</view>
      </view>
      <view class="ad-loading-text">正在加载广告，请稍候...</view>
    </view>

    <view class="loading-section" wx:if="{{loading}}">
      <view class="loading-animation">
        <view class="loading-ring"></view>
        <view class="loading-ring"></view>
        <view class="loading-ring"></view>
      </view>
      <view class="loading-text">正在去水印中，请稍候...</view>
    </view>

    <view class="error-section" wx:if="{{error}}">
      <view class="error-card">
        <view class="error-icon">⚠️</view>
        <view class="error-message">{{error}}</view>
      </view>
    </view>

    <view class="result-section" wx:if="{{videoData && !loading}}">
      <view class="result-header">
        <view class="result-title">解析结果</view>
      </view>
      
      <view class="video-card">
        <view class="video-preview" catchtap="toggleVideoPreview">
          <image class="video-cover-modern {{showVideoPreview ? 'hide' : ''}}" src="{{videoData.cover}}" mode="aspectFit"></image>
          <video 
            class="video-player {{showVideoPreview ? '' : 'hide'}}" 
            src="{{videoData.url}}" 
            id="previewVideo"
            controls="{{false}}"
            show-center-play-btn="{{false}}"
            show-fullscreen-btn="{{false}}"
            poster="{{videoData.cover}}"
            autoplay="{{false}}"
            object-fit="contain"
            bindplay="onVideoPlay"
            bindpause="onVideoPause"
            bindended="onVideoEnded"
            binderror="onVideoError"
            enable-play-gesture="{{false}}"
          ></video>
          <view class="video-overlay {{showVideoPreview ? 'hide' : ''}}">
            <view class="play-icon">▶</view>
            <view class="preview-tip">点击预览视频</view>
          </view>
          <view class="refresh-video {{showVideoPreview ? '' : 'hide'}}" bindtap="refreshVideo" catchtap="true">
            <view class="refresh-icon">↻</view>
            <view class="refresh-text">刷新</view>
          </view>
        </view>
        
        <view class="video-info">
          <view class="video-actions-modern">
            <view class="action-btn primary-action" bindtap="downloadVideo">
              <view class="action-text">下载视频</view>
            </view>
            <view class="action-btn secondary-action" bindtap="copyLink">
              <view class="action-text">复制链接</view>
            </view>
          </view>
          
          <view class="link-toggle-modern" bindtap="toggleLinkDisplay">
            <view class="toggle-text">{{showLink ? '隐藏链接' : '查看链接'}}</view>
            <view class="toggle-icon">{{showLink ? '▲' : '▼'}}</view>
          </view>
          
          <view class="link-panel" wx:if="{{showLink}}">
            <view class="link-header">
              <view class="link-title">无水印视频链接</view>
              <view class="copy-btn" bindtap="copyLink">一键复制</view>
            </view>
            <view class="link-content">
              <text class="link-text">{{videoData.url}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="tech-support-fixed">
      <view class="tech-support-content">
        <view class="tech-support-line">视频或图集素材归平台作者所有</view>
        <view class="tech-support-line">本小程序不储存任何视频及图片</view>
      </view>
    </view>

    <custom-tabbar currentIndex="0"></custom-tabbar>
  </view>
</view>
