.page-container {
  width: 100%;
  background: var(--color-bg);
  position: relative;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  padding-top: 0;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  color: var(--color-text-secondary);
  min-height: 100vh;
}

.announcement-bar {
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
  padding: var(--spacing-sm) var(--spacing-lg);
  overflow: hidden;
  position: relative;
  left: 0;
  right: 0;
  width: 100%;
  box-sizing: border-box;
  z-index: 998;
  margin: 0;
  border: none;
  border-bottom: 2px solid var(--color-primary);
  box-shadow: var(--shadow-sm);
}

.announcement-wrapper {
  position: relative;
  width: 100%;
  height: 40rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.announcement-content-wrapper {
  flex: 1;
  position: relative;
  overflow: hidden;
  height: 100%;
}

.announcement-content {
  position: absolute;
  top: 2rpx;
  white-space: nowrap;
  animation: announcement-scroll 15s linear infinite;
  display: flex;
  padding-right: 100rpx;
}

.announcement-text {
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 40rpx;
}

.iconfont {
  font-size: 32rpx;
  line-height: 1;
}

.container {
  padding: var(--spacing-lg);
  position: relative;
  padding-bottom: var(--spacing-xxl);
  box-sizing: border-box;
  margin-top: var(--spacing-md);
  max-width: 100%;
  overflow: hidden;
  z-index: 1;
}

.header-section {
  text-align: center;
  margin-bottom: var(--spacing-xl);
  padding-top: var(--spacing-sm);
  animation: fadeInDown 0.8s ease-out;
  position: relative;
}

.main-title {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 50%, #FFD93D 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: var(--spacing-sm);
  letter-spacing: 2rpx;
  line-height: 1.2;
  text-shadow: 0 2px 8px rgba(255, 107, 53, 0.1);
}

.sub-title {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  font-weight: 400;
  margin-bottom: var(--spacing-md);
}

.notice-compact {
  margin: 0 auto;
  padding: var(--spacing-md) var(--spacing-lg);
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
  border-radius: var(--radius-lg);
  border: 2px solid var(--color-primary);
  max-width: 85%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-md);
}

.notice-label {
  font-size: 32rpx;
  color: var(--color-primary);
  line-height: 1.5;
  font-weight: 700;
  margin-bottom: var(--spacing-xs);
  letter-spacing: 8rpx;
}

.notice-compact-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  font-weight: 400;
  text-align: left;
  width: 90%;
  margin: 0 auto;
}

.input-section {
  margin-bottom: var(--spacing-xl);
  animation: fadeInUp 0.8s ease-out 0.2s both;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 0;
  margin: 0 auto var(--spacing-lg) auto;
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  border: 2px solid var(--color-border);
  overflow: hidden;
}

.input-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-md);
  border-bottom: 2px solid var(--color-border);
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
}

.input-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.input-wrapper {
  padding: var(--spacing-md) var(--spacing-xl);
  position: relative;
}

.input-modern {
  width: 100%;
  padding: var(--spacing-md) 0;
  border: none;
  border-radius: 0;
  font-size: 30rpx;
  background: transparent;
  color: var(--color-text-primary);
  min-height: 130rpx;
  height: 85rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
  line-height: 1.6;
  font-weight: 400;
  text-align: left;
}

.input-modern::placeholder {
  color: var(--color-text-placeholder);
  font-weight: 300;
}

.button-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-modern {
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 50%, #FFD93D 100%);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 700;
  padding: 0;
  margin: 0 auto;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-modern::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.5s ease;
}

.btn-modern:active::before {
  left: 100%;
}

.btn-modern:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.btn-ready {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 50%, #FFD93D 100%);
  box-shadow: var(--shadow-md);
}

.btn-disabled {
  background: linear-gradient(180deg, #F5F5F5 0%, #E8E8E8 100%);
  color: #000000;
  box-shadow: none;
  border: 1px solid var(--color-border);
}

.btn-disabled .btn-text {
  color: #000000;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 50rpx;
  line-height: 0rpx;
}

.btn-modern .btn-text {
  font-weight: 700;
}

.customer-service-wrapper {
  position: fixed;
  bottom: 300rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  z-index: 1000;
}

.customer-service-ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: transparent;
  border: 2px solid rgba(255, 107, 53, 0.6);
  transform: translate(-50%, -50%);
  animation: ripple 2s ease-out infinite;
}

.customer-service-ripple::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: transparent;
  border: 2px solid rgba(255, 107, 53, 0.4);
  transform: translate(-50%, -50%);
  animation: ripple 2s ease-out infinite 1s;
}

.customer-service-float {
  position: absolute;
  top: 0;
  left: 0;
  width: 100rpx;
  height: 100rpx;
  min-width: 100rpx;
  min-height: 100rpx;
  max-width: 100rpx;
  max-height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.3s ease;
  box-sizing: border-box;
  line-height: 100rpx;
}

.customer-service-float:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.customer-service-wrapper:active .customer-service-ripple,
.customer-service-wrapper:active .customer-service-ripple::before {
  animation: none;
  opacity: 0;
}

.customer-service-float::after {
  border: none;
}

.service-text-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
}

.service-text-line {
  font-size: 22rpx;
  line-height: 1.2;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: block;
}

.service-text-line:first-child {
  margin-bottom: 4rpx;
}

.service-icon {
  width: 60rpx;
  height: 60rpx;
}

@keyframes ripple {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.6);
    opacity: 0;
  }
}

.ad-loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: var(--spacing-xl) 0;
  animation: fadeIn 0.6s ease-out;
}

.ad-loading-animation {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-loading-icon {
  font-size: 90rpx;
  animation: bounce 1.8s infinite ease-in-out;
}

@keyframes bounce {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.8;
  }
  50% { 
    transform: scale(1.2); 
    opacity: 1;
  }
}

.ad-loading-text {
  color: var(--color-text-secondary);
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: var(--spacing-xl) 0;
  animation: fadeIn 0.6s ease-out;
}

.loading-animation {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: var(--spacing-lg);
}

.loading-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 8rpx solid transparent;
}

.loading-ring:nth-child(1) {
  border-top-color: var(--color-primary);
  animation: spin 1.8s linear infinite;
}

.loading-ring:nth-child(2) {
  border-right-color: var(--color-primary);
  animation: spin 2.3s linear infinite reverse;
  width: 80%;
  height: 80%;
  top: 10%;
  left: 10%;
}

.loading-ring:nth-child(3) {
  border-bottom-color: var(--color-primary);
  animation: spin 2.8s linear infinite;
  width: 60%;
  height: 60%;
  top: 20%;
  left: 20%;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  color: var(--color-text-secondary);
  font-size: 32rpx;
  font-weight: 500;
}

.error-section {
  margin: var(--spacing-lg) 0;
  animation: shake 0.6s ease-out;
}

.error-card {
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  border: 2px solid var(--color-error);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-md);
}

.error-icon {
  font-size: 45rpx;
  margin-right: var(--spacing-md);
}

.error-message {
  color: var(--color-text-secondary);
  font-size: 30rpx;
  font-weight: 400;
  flex: 1;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx); }
}

.result-section {
  margin-top: var(--spacing-xl);
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
  padding: 0 var(--spacing-lg);
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
  position: relative;
}

.result-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 60rpx;
  height: 3rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

.video-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  border: 2px solid var(--color-border);
  transition: all 0.3s ease;
  position: relative;
  margin: 0 var(--spacing-lg);
  width: calc(100% - 60rpx);
}

.video-preview {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
  border-bottom: 2px solid var(--color-border);
  background: #000000;
}

.video-cover-modern {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.hide {
  display: none !important;
}

.video-player {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  background-color: #000;
}

.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transition: opacity 0.3s ease;
}

.play-icon {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #FFFFFF;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-lg);
  line-height: 1;
  padding-left: 5rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.preview-tip {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
}

.refresh-video {
  position: absolute;
  top: var(--spacing-md);
  right: var(--spacing-md);
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  border: none;
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s ease;
}

.refresh-video:active {
  transform: scale(0.95);
}

.refresh-icon {
  font-size: 30rpx;
  color: #FFFFFF;
  margin-right: var(--spacing-xs);
}

.refresh-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.video-info {
  padding: var(--spacing-lg);
  border-top: 2px solid var(--color-border);
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
}

.video-actions-modern {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-btn:active {
  transform: scale(0.98);
}

.primary-action {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #FFFFFF;
  box-shadow: var(--shadow-md);
  border: none;
}

.secondary-action {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF9E6 100%);
  color: var(--color-primary);
  box-shadow: var(--shadow-sm);
  border: 2px solid var(--color-primary);
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
}

.link-toggle-modern {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md);
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF9E6 100%);
  border-radius: var(--radius-md);
  border: 2px solid var(--color-border);
  margin-bottom: var(--spacing-md);
  transition: all 0.3s ease;
}

.link-toggle-modern:active {
  transform: scale(0.98);
  background: linear-gradient(180deg, #FFF5EB 0%, #FFE8CC 100%);
}

.toggle-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-right: var(--spacing-xs);
}

.toggle-icon {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.link-panel {
  background: linear-gradient(180deg, #FFF5EB 0%, #FFE8CC 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  border: 2px solid var(--color-border);
}

.link-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.link-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.copy-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-white);
  border-radius: var(--radius-sm);
  border: 2px solid var(--color-primary);
}

.link-content {
  background: var(--color-white);
  border-radius: var(--radius-sm);
  padding: var(--spacing-md);
  border: 2px solid var(--color-border);
}

.link-code {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  word-break: break-all;
  line-height: 1.5;
}

.harmonyos-tip {
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  text-align: center;
  border: 1px solid var(--color-border);
}

.harmonyos-tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.tech-support-fixed {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #FFF5EB 0%, #FFE8CC 100%);
  border-top: 2px solid var(--color-primary);
  padding: 8rpx var(--spacing-lg);
  z-index: 999;
  box-shadow: var(--shadow-sm);
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.tech-support-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tech-support-line {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
  line-height: 1.5;
  text-align: center;
}
