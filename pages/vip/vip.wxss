/* pages/vip/vip.wxss */
page {
  height: 100%;
  overflow: visible;
}

.vip-container {
  min-height: 100%;
  background-color: #F5F5F5;
  padding-bottom: 200rpx;
}

/* 顶部用户信息区 */
.user-info-section {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
}

.user-info-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  border-radius: 0 0 40rpx 40rpx;
  animation: gradientAnimation 3s ease infinite;
}

@keyframes gradientAnimation {
 0% {
   background-position: 0% 50%;
 }
 50% {
   background-position: 100% 50%;
 }
 100% {
   background-position: 0% 50%;
 }
}

.user-info-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-details {
  margin-left: 24rpx;
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(255, 107, 53, 0.4);
}

.user-id {
  font-size: 26rpx;
  color: #999999;
}

.login-prompt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-tip {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.login-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 积分展示区 */
.points-section {
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.points-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 50%, #FFB366 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.points-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.points-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.points-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.points-divider {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
}

/* 免费解析次数区 */
.free-section {
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #FF6B35;
}

.free-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.free-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.free-label {
  font-size: 28rpx;
  color: #666666;
}

.free-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B35;
}

.progress-bar {
  display: flex;
  align-items: center;
}

.progress-bg {
  flex: 1;
  height: 16rpx;
  background-color: #EEEEEE;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #999999;
  min-width: 60rpx;
  text-align: right;
}

/* 今日任务区 */
.task-section {
  padding: 0 30rpx;
}

.task-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.task-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.task-detail {
  display: flex;
  align-items: center;
}

.detail-label {
  font-size: 26rpx;
  color: #999999;
}

.detail-value {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.detail-value.accent {
  color: #FF6B35;
  font-weight: 600;
}

.claim-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.claim-btn.disabled {
  background: #CCCCCC;
}

.claim-btn::after {
  border: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 积分说明区 */
.rules-section {
  padding: 30rpx;
  padding-bottom: 100rpx;
}

.rules-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-bullet {
  color: #FF6B35;
  font-size: 28rpx;
  margin-right: 12rpx;
  font-weight: 600;
}

.rule-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
