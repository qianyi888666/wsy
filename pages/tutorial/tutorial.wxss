/* pages/tutorial/tutorial.wxss */

.tutorial-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  overflow-x: hidden;
}

.tutorial-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  padding: 40rpx 40rpx 40rpx;
  text-align: center;
  border-radius: 30rpx;
  animation: gradientAnimation 3s ease infinite;
  margin: 20rpx;
}

@keyframes gradientAnimation {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 3rpx 3rpx 6rpx #000000;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 2rpx 2rpx 4rpx #000000;
}

.tutorial-content {
  padding: 30rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5e 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.section-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.subsection {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.subsection-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff6b35;
  margin-bottom: 16rpx;
}

.subsection-content {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 32rpx;
  color: #999999;
  font-weight: 500;
}
