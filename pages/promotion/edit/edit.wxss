.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.form-container {
  padding: 30rpx;
}

.form-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.input-wrapper, .textarea-wrapper {
  position: relative;
}

.input-wrapper input, .textarea-wrapper textarea {
  position: relative;
  z-index: 1;
  background: transparent;
  width: 100%;
  height: 80rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.textarea-wrapper textarea {
  min-height: 160rpx;
  height: auto;
}

.input-placeholder {
  position: absolute;
  top: 0;
  left: 20rpx;
  z-index: 2;
  font-size: 28rpx;
  color: #999;
  display: flex;
  align-items: center;
  pointer-events: none;
  width: 100%;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
}

.textarea-wrapper .input-placeholder {
  align-items: flex-start;
  padding-top: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.form-input-placeholder {
  color: #999 !important;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.textarea-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.link-textarea .textarea-counter {
  display: none;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.picker-trigger {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-trigger.placeholder {
  color: #999;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

.cover-uploader-box {
  position: relative;
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cover-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

.change-cover-btn {
  margin-top: 20rpx;
  padding: 16rpx 32rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.cover-uploader {
  width: 100%;
  height: 100%;
}

.cover-uploader.has-image {
  position: relative;
}

.cover-change-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 48rpx;
  color: #ccc;
  background-color: #fff;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F65 100%);
  border-radius: 44rpx;
}

.submit-btn.disabled {
  opacity: 0.6;
}