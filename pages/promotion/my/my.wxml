<view class="page-container">
  <scroll-view 
    scroll-y 
    class="promotion-list"
    bindscrolltolower="onLoadMore"
  >
    <view class="promotion-item" wx:for="{{myPromotions}}" wx:key="id">
      <image 
        class="item-cover" 
        src="{{item.cover_image || '/images/default-cover.png'}}" 
        mode="aspectFill"
      ></image>
      <view class="item-content">
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc" wx:if="{{item.description}}">{{item.description}}</view>
        <view class="item-meta">
          <view class="status {{item.status == 1 ? 'active' : 'inactive'}}">
            {{item.status == 1 ? '上架中' : '已下架'}}
          </view>
          <text class="category" wx:if="{{item.category}}">{{item.category}}</text>
          <text class="date">{{item.created_at}}</text>
        </view>
      </view>
      <view class="item-actions">
        <view class="action-btn edit" bindtap="editPromotion" data-id="{{item.id}}">编辑</view>
        <view 
          class="action-btn {{item.status == 1 ? 'down' : 'up'}}" 
          bindtap="toggleStatus" 
          data-id="{{item.id}}"
          data-status="{{item.status}}"
        >
          {{item.status == 1 ? '下架' : '上架'}}
        </view>
        <view class="action-btn delete" bindtap="deletePromotion" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{myPromotions.length === 0 && !loading}}">
      <image class="empty-icon" src="/images/empty-promotion.png" mode="aspectFit"></image>
      <text class="empty-text">您还没有发布推广</text>
      <text class="empty-hint">快去发布第一个推广吧</text>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-icon"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && myPromotions.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <view class="publish-btn-wrap">
    <view class="publish-btn" bindtap="goToPublish">
      <text class="btn-icon">+</text>
      <text class="btn-text">发布新推广</text>
    </view>
  </view>
</view>