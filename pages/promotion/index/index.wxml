<view class="page-container">
  <view class="sticky-header">
    <view class="page-header">
      <view class="search-bar">
        <icon type="search" size="16" color="#999"></icon>
        <input 
          class="search-input" 
          placeholder="搜索推广内容" 
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
        />
      </view>
    </view>
  </view>

  <scroll-view 
    scroll-y 
    class="promotion-list"
    bindscrolltolower="onLoadMore"
    enable-flex="{{true}}"
    scroll-top="{{scrollTop}}"
  >
    <view class="waterfall" wx:if="{{promotions.length > 0}}">
      <view class="waterfall-row" wx:for="{{promotions}}" wx:key="id" wx:if="{{index % 2 === 0}}">
        <view class="promotion-card" hover-class="promotion-card-hover" hover-stay-time="100" bindtap="onCardTap" data-item="{{promotions[index]}}">
          <image class="card-cover" src="{{promotions[index].cover_image || '/images/default-cover.png'}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view class="card-content">
            <view class="card-title">{{promotions[index].title}}</view>
            <view class="card-desc" wx:if="{{promotions[index].description}}">{{promotions[index].description}}</view>
            <view class="card-author">
              <image class="author-avatar" src="{{promotions[index].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <text class="author-name">{{promotions[index].nickname || '匿名用户'}}</text>
            </view>
          </view>
        </view>
        <view class="promotion-card" hover-class="promotion-card-hover" hover-stay-time="100" wx:if="{{promotions[index + 1]}}" bindtap="onCardTap" data-item="{{promotions[index + 1]}}">
          <image class="card-cover" src="{{promotions[index + 1].cover_image || '/images/default-cover.png'}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view class="card-content">
            <view class="card-title">{{promotions[index + 1].title}}</view>
            <view class="card-desc" wx:if="{{promotions[index + 1].description}}">{{promotions[index + 1].description}}</view>
            <view class="card-author">
              <image class="author-avatar" src="{{promotions[index + 1].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <text class="author-name">{{promotions[index + 1].nickname || '匿名用户'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{!loading}}">
      <image class="empty-icon" src="/images/empty-promotion.png" mode="aspectFit"></image>
      <text class="empty-text">暂无推广内容</text>
      <text class="empty-hint">快去发布第一个推广吧</text>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-icon"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && promotions.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <custom-tabbar currentIndex="1"></custom-tabbar>
</view>