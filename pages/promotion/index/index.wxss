.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  animation: gradientMove 3s ease infinite;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
}

.page-header {
  padding: 30rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  animation: gradientMove 3s ease infinite;
}

@keyframes gradientMove {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-left: 16rpx;
}

.search-placeholder {
  color: #999;
}

.category-tabs {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 24rpx 0;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF6B35;
  border-radius: 3rpx;
}

.promotion-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  height: calc(100vh - 300rpx);
}

.waterfall {
  display: flex;
  flex-direction: column;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.waterfall-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.promotion-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  width: 48%;
  box-sizing: border-box;
  transition: all 0.2s ease;
  position: relative;
  min-height: 400rpx;
}

.promotion-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.promotion-card-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.card-cover {
  width: 100%;
  display: block;
  background-color: #f0f0f0;
}

.card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.7) 50%, transparent 100%);
  color: #fff;
}

.card-overlay .card-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.5);
}

.card-overlay .card-desc {
  color: rgba(255,255,255,0.95);
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.5);
}

.card-content {
  padding: 24rpx 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.card-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 72rpx;
}

.card-author {
  display: flex;
  align-items: center;
  z-index: 2;
}

.author-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background-color: #f0f0f0;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.author-name {
  font-size: 22rpx;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.5);
}

.card-overlay.light {
  background: rgba(255, 255, 255, 0.95);
}

.card-overlay.light {
  background: rgba(255, 255, 255, 0.95);
}

.card-overlay.light .card-title {
  color: #333;
  text-shadow: none;
}

.card-overlay.light .card-desc {
  color: #666;
  text-shadow: none;
}

.card-author.light .author-name {
  color: #333;
  text-shadow: none;
}

.card-author.light .author-avatar {
  border-color: #ddd;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-icon {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #eee;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #ccc;
}