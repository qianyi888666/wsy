<view class="points-log-container">
  <view class="balance-card">
    <view class="balance-label">当前积分余额</view>
    <view class="balance-amount">{{summary.balance}}</view>
    <view class="balance-summary">
      <view class="summary-item earn">
        <text class="summary-label">获得</text>
        <text class="summary-value">{{summary.totalEarned}}</text>
      </view>
      <view class="summary-item consume">
        <text class="summary-label">消耗</text>
        <text class="summary-value">{{summary.totalConsumed}}</text>
      </view>
    </view>
  </view>

  <view class="filter-section">
    <view class="filter-row">
      <picker mode="date" value="{{startDate}}" start="2020-01-01" end="2030-12-31" bindchange="onStartDateChange">
        <view class="filter-item">
          <text class="{{startDate ? '' : 'placeholder'}}">{{startDate || '开始日期'}}</text>
        </view>
      </picker>
      <text class="date-separator">-</text>
      <picker mode="date" value="{{endDate}}" start="2020-01-01" end="2030-12-31" bindchange="onEndDateChange">
        <view class="filter-item">
          <text class="{{endDate ? '' : 'placeholder'}}">{{endDate || '结束日期'}}</text>
        </view>
      </picker>
      <view class="filter-reset" bindtap="resetFilters">重置</view>
    </view>
  </view>

  <view class="tab-section">
    <view class="tab-list">
      <view
        class="tab-item {{currentTab === 'all' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="all"
      >
        全部
      </view>
      <view
        class="tab-item {{currentTab === 'earn' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="earn"
      >
        获得
      </view>
      <view
        class="tab-item {{currentTab === 'consume' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="consume"
      >
        消耗
      </view>
    </view>
  </view>

  <scroll-view
    class="log-list"
    scroll-y
    bindscrolltolower="loadMore"
    enable-flex="true"
    lower-threshold="100"
  >
    <block wx:if="{{logList.length > 0}}">
      <view class="log-item" wx:for="{{logList}}" wx:key="id">
        <view class="log-icon">
          <text wx:if="{{item.points > 0}}">📺</text>
          <text wx:else>🎬</text>
        </view>
        <view class="log-content">
          <view class="log-action">{{item.actionName}}</view>
          <view class="log-time">{{item.createdAt}}</view>
          <view class="log-remark" wx:if="{{item.remark}}">{{item.remark}}</view>
        </view>
        <view class="log-points {{item.points > 0 ? 'positive' : 'negative'}}">
          <text wx:if="{{item.points > 0}}">+</text>{{item.points}}
        </view>
      </view>
    </block>

    <block wx:elif="{{!isLoading}}">
      <view class="empty-state">
        <view class="empty-icon">📭</view>
        <view class="empty-text">暂无积分记录</view>
        <view class="empty-hint">快去获取积分吧～</view>
      </view>
    </block>

    <view class="load-more" wx:if="{{logList.length > 0}}">
      <block wx:if="{{isLoading}}">
        <view class="loading-view">
          <view class="loading-spinner"></view>
          <text>正在加载...</text>
        </view>
      </block>
      <block wx:elif="{{noMore}}">
        <view class="no-more-text">没有更多了</view>
      </block>
      <block wx:else>
        <view class="load-more-btn" bindtap="loadMore">加载更多</view>
      </block>
    </view>
  </scroll-view>

  <custom-tabbar currentIndex="1"></custom-tabbar>
</view>