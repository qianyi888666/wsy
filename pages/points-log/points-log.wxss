page {
  height: 100%;
  background-color: #F5F5F5;
}

.points-log-container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

@keyframes gradientAnimation {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.balance-card {
  margin: 20rpx 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
  color: #FFFFFF;
  animation: gradientAnimation 3s ease infinite;
}

.balance-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
  text-shadow: 2rpx 2rpx 4rpx #000000;
}

.balance-amount {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-shadow: 3rpx 3rpx 6rpx #000000;
}

.balance-summary {
  display: flex;
  justify-content: flex-start;
  gap: 60rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 600;
  text-shadow: 2rpx 2rpx 4rpx #000000;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.8;
  text-shadow: 1rpx 1rpx 2rpx #000000;
}

.filter-section {
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-item {
  flex: 1;
  height: 64rpx;
  min-width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.filter-item .placeholder {
  color: #BBBBBB;
}

.date-separator {
  color: #999999;
  flex: 0 0 30rpx;
  text-align: center;
}

.filter-reset {
  flex: 0 0 100rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF5EB;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #FF6B35;
}

.tab-section {
  background-color: #FFFFFF;
  padding: 0 30rpx 20rpx;
}

.tab-list {
  display: flex;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666666;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background-color: #FF6B35;
  color: #FFFFFF;
  font-weight: 600;
}

.log-list {
  flex: 1;
  padding: 0 30rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.log-item {
  display: flex;
  align-items: flex-start;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.log-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF5EB;
  border-radius: 50%;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.log-content {
  flex: 1;
}

.log-action {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.log-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.log-remark {
  font-size: 24rpx;
  color: #666666;
}

.log-points {
  font-size: 32rpx;
  font-weight: 700;
  min-width: 100rpx;
  text-align: right;
}

.log-points.positive {
  color: #52C41A;
}

.log-points.negative {
  color: #FF4D4F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.load-more {
  padding: 20rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: 16rpx 60rpx;
  background-color: #FF6B35;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.loading-view {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #999999;
  font-size: 24rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E5E5E5;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.no-more-text {
  font-size: 24rpx;
  color: #CCCCCC;
}