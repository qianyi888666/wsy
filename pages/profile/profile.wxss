.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.user-info-section {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
}

.user-info-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFFFFF 100%);
  background-size: 200% 200%;
  border-radius: 0 0 40rpx 40rpx;
  animation: gradientAnimation 3s ease infinite;
}

@keyframes gradientAnimation {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.user-info-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.avatar-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-details {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(255, 107, 53, 0.4);
}

.nickname-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.settings-icon {
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  margin-left: 6rpx;
  position: relative;
  top: -2rpx;
}

.settings-icon text {
  font-size: 28rpx;
}

.nickname-center {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-top: 20rpx;
  text-align: center;
}

.user-id {
  font-size: 26rpx;
  color: #999999;
}

.user-points {
  font-size: 26rpx;
  color: #FF6B35;
  margin-top: 8rpx;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.login-tip {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666666;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn .avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.nickname-input-wrapper {
  margin-top: 20rpx;
  width: 80%;
}

.nickname-input {
  width: 100%;
  padding: 16rpx 30rpx;
  background-color: #F5F5F5;
  border-radius: 44rpx;
  font-size: 28rpx;
  text-align: center;
}

.login-btn {
  margin-top: 30rpx;
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.login-btn:active,
.login-btn.btn-pressing {
  opacity: 0.8;
  transform: scale(0.98);
}

.login-btn::after {
  border: none;
}

.logout-btn::after {
  border: none;
}

.menu-section {
  margin: 0 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.menu-list {
  padding: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 10rpx;
  position: relative;
}

button.menu-item {
  background-color: #FFFFFF;
  border: none;
  border-radius: 0;
  margin: 0;
  width: 100%;
  line-height: normal;
}

button.menu-item::after {
  display: none;
}

.menu-item.has-border {
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: normal;
  flex: 1;
  text-align: left;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background-color: #FFFFFF;
  width: 640rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  position: relative;
  padding: 32rpx 30rpx 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.modal-close {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
}

.modal-body {
  padding: 40rpx 40rpx 32rpx;
}

.version-item {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.version-item:last-of-type {
  border-bottom: none;
}

.version-label {
  font-size: 28rpx;
  color: #999999;
  margin-right: 16rpx;
}

.version-value {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 600;
}

.version-desc {
  margin-top: 32rpx;
  padding-top: 24rpx;
  text-align: center;
}

.version-desc .desc-line {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.version-desc .highlight {
  color: #FF6B35;
  font-weight: 600;
}

.copyright {
  margin-top: 20rpx;
  text-align: center;
}

.copyright text {
  display: block;
  font-size: 22rpx;
  color: #BBBBBB;
  line-height: 1.8;
}

.logout-section {
  padding: 30rpx;
  margin-top: 30rpx;
}

.logout-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  text-align: center;
}

.logout-btn:active,
.logout-btn.btn-pressing {
  opacity: 0.8;
  transform: scale(0.98);
}

.logout-btn::after {
  border: none;
}
