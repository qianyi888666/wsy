/* pages/profile/edit/edit.wxss */
page {
  background-color: #F5F5F5;
}

.edit-container {
  display: flex;
  flex-direction: column;
  padding-bottom: 160rpx;
}

/* 表单内容 */
.form-content {
  flex: 1;
  padding: 40rpx 30rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-wrapper:active .avatar-mask {
  opacity: 1;
}

.camera-icon {
  font-size: 48rpx;
}

.avatar-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999999;
}

/* 输入区域 */
.input-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.input-wrapper {
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.nickname-input {
  font-size: 30rpx;
  color: #333333;
  width: 100%;
  height: 44rpx;
  line-height: 44rpx;
}

.input-counter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.input-counter.has-error {
  color: #FF4D4F;
}

.error-text {
  margin-left: 20rpx;
}

/* 底部按钮区域 */
.btn-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
}

.btn-section button {
  flex: 1;
  margin: 0 10rpx;
}

.btn-section button:first-child {
  margin-left: 0;
}

.btn-section button:last-child {
  margin-right: 0;
}

.btn-primary {
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-primary.btn-loading {
  opacity: 0.8;
}

.btn-primary[disabled] {
  background: #FFAB91;
  color: rgba(255, 255, 255, 0.6);
}

.btn-secondary {
  height: 88rpx;
  background-color: transparent;
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #666666;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #DDDDDD;
}

.btn-secondary:active {
  background-color: #F5F5F5;
}

.btn-secondary[disabled] {
  opacity: 0.5;
}
